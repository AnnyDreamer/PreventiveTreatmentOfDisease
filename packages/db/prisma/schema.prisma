generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户角色枚举
enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

// 9种中医体质类型
enum ConstitutionType {
  BALANCED        // 平和质
  QI_DEFICIENCY   // 气虚质
  YANG_DEFICIENCY // 阳虚质
  YIN_DEFICIENCY  // 阴虚质
  PHLEGM_DAMPNESS // 痰湿质
  DAMP_HEAT       // 湿热质
  BLOOD_STASIS    // 血瘀质
  QI_STAGNATION   // 气郁质
  SPECIAL         // 特禀质
}

// 风险等级
enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// 随访状态
enum FollowupStatus {
  PENDING
  COMPLETED
  MISSED
  CANCELLED
}

// 用户表
model User {
  id        String   @id @default(cuid())
  phone     String?  @unique
  openid    String?  @unique
  unionid   String?
  name      String?
  avatar    String?
  role      Role     @default(PATIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientProfile  PatientProfile?
  doctorProfile   DoctorProfile?
  assessments     ConstitutionAssessment[]
  healthPlans     HealthPlan[]
  diaryEntries    DiaryEntry[]
  chatSessions    ChatSession[]

  hospitalId      String?
  hospital        Hospital? @relation(fields: [hospitalId], references: [id])

  @@index([role])
  @@index([hospitalId])
}

// 患者档案
model PatientProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gender      String?
  birthDate   DateTime?
  height      Float?
  weight      Float?
  allergies   Json?     // string[]
  medicalHistory Json?  // string[]
  riskLevel   RiskLevel @default(LOW)
  lastVisitDate DateTime?
  primaryConstitution ConstitutionType?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  followupEnrollments    FollowupEnrollment[]
  reminderLogs           ReminderLog[]
  activityRegistrations  ActivityRegistration[]
  serviceAppointments    ServiceAppointment[]
}

// 医生档案
model DoctorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String?  // 职称
  department  String?  // 科室
  specialty   String?  // 专长
  licenseNo   String?  // 执业证号
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  followupPlans        FollowupPlan[]
  publishedActivities  WellnessActivity[]
  serviceSchedules     ServiceSchedule[]
  serviceAppointments  ServiceAppointment[]
}

// 体质评估
model ConstitutionAssessment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers     Json     // Record<string, number> 问卷答案
  scores      Json     // Record<ConstitutionType, number> 各体质得分
  primaryType ConstitutionType
  secondaryTypes Json? // ConstitutionType[] 兼夹体质
  aiAnalysis  String?  @db.Text  // AI分析结果
  createdAt   DateTime @default(now())

  healthPlan  HealthPlan?

  @@index([userId])
  @@index([primaryType])
}

// 养生方案
model HealthPlan {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessmentId String   @unique
  assessment   ConstitutionAssessment @relation(fields: [assessmentId], references: [id])

  dietAdvice      Json  // 饮食建议 {recommended: string[], avoid: string[], recipes: string[]}
  exerciseAdvice  Json  // 运动建议
  lifestyleAdvice Json  // 起居建议
  emotionAdvice   Json  // 情志建议
  acupointAdvice  Json? // 穴位建议

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// 健康日记
model DiaryEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date

  sleepHours    Float?
  sleepQuality  Int?    // 1-5
  moodScore     Int?    // 1-5
  exerciseMinutes Int?
  exerciseType  String?
  dietNote      String?
  symptoms      Json?   // string[]
  note          String? @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
}

// AI对话会话
model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  ChatMessage[]

  @@index([userId])
}

// AI对话消息
model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String   // "user" | "assistant" | "system"
  content   String   @db.Text
  metadata  Json?    // 意图识别、安全标记等
  createdAt DateTime @default(now())

  @@index([sessionId])
}

// 随访计划（面向患者群体）
model FollowupPlan {
  id          String   @id @default(cuid())
  doctorId    String?
  doctor      DoctorProfile? @relation(fields: [doctorId], references: [id])

  name        String
  description String?  @db.Text

  // 目标人群筛选条件
  targetConstitutions Json   // ConstitutionType[] 目标体质类型
  targetRiskLevels   Json?  // RiskLevel[] 目标风险等级（可选，不填则不限）

  startDate   DateTime
  endDate     DateTime?
  intervalDays Int     @default(7)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments FollowupEnrollment[]

  @@index([doctorId])
}

// 随访登记（计划与患者的关联）
model FollowupEnrollment {
  id          String   @id @default(cuid())
  planId      String
  plan        FollowupPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  patientId   String
  patient     PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  enrolledAt  DateTime @default(now())

  records     FollowupRecord[]

  @@unique([planId, patientId])
  @@index([planId])
  @@index([patientId])
}

// 随访记录
model FollowupRecord {
  id           String   @id @default(cuid())
  enrollmentId String
  enrollment   FollowupEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  scheduledDate DateTime
  completedDate DateTime?
  status      FollowupStatus @default(PENDING)

  feedback    Json?    // 患者反馈
  aiSummary   String?  @db.Text
  riskFlag    Boolean  @default(false)
  riskNote    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enrollmentId])
  @@index([status])
  @@index([scheduledDate])
}

// ============================================================
// 康养服务分类枚举
// ============================================================
enum ServiceCategory {
  MOXIBUSTION    // 艾灸
  SANFU_PATCH    // 三伏贴
  TUINA          // 推拿
  MASSAGE        // 按摩
  ACUPUNCTURE    // 针灸
  HERBAL_DRINK   // 中药饮
  OTHER
}

// 健康内容类型枚举
enum ContentType {
  SOLAR_TERM          // 节气养生
  CONSTITUTION_GUIDE  // 体质调养
  DIET_THERAPY        // 食疗
  EXERCISE_GUIDE      // 运动指导
  KNOWLEDGE           // 常识
}

// 活动状态枚举
enum ActivityStatus {
  DRAFT
  PUBLISHED
  ONGOING
  ENDED
  CANCELLED
}

// 预约状态枚举
enum AppointmentStatus {
  PENDING    // 待确认
  CONFIRMED  // 已确认
  COMPLETED  // 已完成
  CANCELLED  // 已取消
  NO_SHOW    // 未到诊
}

// 康养服务
model WellnessService {
  id                  String          @id @default(cuid())
  name                String
  category            ServiceCategory
  description         String          @db.Text
  benefits            Json            // string[]
  precautions         Json            // string[]
  procedure           Json?           // string[] 服务流程步骤
  galleryImages       Json?           // string[] 图片URL列表
  duration            String?
  price               String?
  suitableFor         Json            // ConstitutionType[]
  contraindicatedFor  Json?           // ConstitutionType[]
  isSeasonalOnly      Boolean         @default(false)
  seasonalNote        String?
  coverImage          String?
  isActive            Boolean         @default(true)
  sortOrder           Int             @default(0)
  hospitalId          String
  hospital            Hospital        @relation(fields: [hospitalId], references: [id])
  schedules           ServiceSchedule[]
  appointments        ServiceAppointment[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([hospitalId, isActive])
}

// 医生排班
model ServiceSchedule {
  id            String          @id @default(cuid())
  serviceId     String
  service       WellnessService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  doctorId      String
  doctor        DoctorProfile   @relation(fields: [doctorId], references: [id])
  dayOfWeek     Json            // Int[] 1=周一...7=周日
  startTime     String          // "09:00"
  endTime       String          // "17:00"
  slotDuration  Int             @default(60)
  isActive      Boolean         @default(true)
  note          String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([serviceId])
  @@index([doctorId])
}

// 义诊活动
model WellnessActivity {
  id                   String           @id @default(cuid())
  title                String
  description          String           @db.Text
  location             String
  department           String?
  startTime            DateTime
  endTime              DateTime
  capacity             Int
  currentCount         Int              @default(0)
  status               ActivityStatus   @default(DRAFT)
  targetConstitutions  Json?            // ConstitutionType[]
  coverImage           String?
  tags                 Json?            // string[]
  publishedAt          DateTime?
  hospitalId           String
  hospital             Hospital         @relation(fields: [hospitalId], references: [id])
  publisherId          String?
  publisher            DoctorProfile?   @relation(fields: [publisherId], references: [id])
  registrations        ActivityRegistration[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([hospitalId, status])
  @@index([status, startTime])
}

// 活动报名
model ActivityRegistration {
  id           String           @id @default(cuid())
  activityId   String
  activity     WellnessActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  patientId    String
  patient      PatientProfile   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  status       String           @default("REGISTERED")
  note         String?
  registeredAt DateTime         @default(now())
  cancelledAt  DateTime?

  @@unique([activityId, patientId])
  @@index([patientId])
}

// 健康内容
model HealthContent {
  id            String       @id @default(cuid())
  title         String
  summary       String
  body          String       @db.Text
  contentType   ContentType
  coverImage    String?
  solarTermKey  String?
  constitutions Json         // ConstitutionType[]
  isPublished   Boolean      @default(false)
  publishedAt   DateTime?
  viewCount     Int          @default(0)
  sortOrder     Int          @default(0)
  authorName    String?
  source        String?
  hospitalId    String?
  hospital      Hospital?    @relation(fields: [hospitalId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([contentType, isPublished])
  @@index([solarTermKey])
}

// 提醒记录
model ReminderLog {
  id        String   @id @default(cuid())
  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type      String   // "FOLLOWUP_REMINDER" | "ASSESSMENT_REMINDER"
  note      String?
  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([createdAt])
}

// 康养服务预约
model ServiceAppointment {
  id              String            @id @default(cuid())
  serviceId       String
  service         WellnessService   @relation(fields: [serviceId], references: [id])
  patientId       String
  patient         PatientProfile    @relation(fields: [patientId], references: [id])
  doctorId        String?
  doctor          DoctorProfile?    @relation(fields: [doctorId], references: [id])
  scheduledDate   DateTime          // 预约日期
  scheduledTime   String            // "09:00"
  status          AppointmentStatus @default(PENDING)
  note            String?           // 主诉/备注
  completionNote  String?           // 完成记录
  cancelReason    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([serviceId])
  @@index([patientId])
  @@index([doctorId])
  @@index([status, scheduledDate])
}

// 医院/机构
model Hospital {
  id        String   @id @default(cuid())
  name      String
  level     String?  // 等级：三甲、三乙等
  address   String?
  config    Json?    // 功能开关配置
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  services   WellnessService[]
  activities WellnessActivity[]
  contents   HealthContent[]
}
